# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET="YOUR_AUTH_SECRET_HERE"  # Generated by create-t3-app.

# Next Auth Email Provider (MailDev - Local SMTP)
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_FROM=noreply@localhost

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="YOUR_DATABASE_URL_HERE"

# CLOUDINARY API KEY
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME_HERE"
CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME_HERE"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY_HERE"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET_HERE"

# STRIPE API KEY
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY_HERE"
STRIPE_PUBLISHABLE_KEY="YOUR_STRIPE_PUBLISHABLE_KEY_HERE"

STRIPE_WEBHOOK_SECRET="YOUR_STRIPE_WEBHOOK_SECRET_HERE"

# OAuth GitHub
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID_HERE"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET_HERE"

# OAuth Google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET_HERE"

# Pyroscope (Grafana Cloud) continuous profiling.
# Set ENABLE_PROFILING=true to run the profiler outside of production.
ENABLE_PROFILING="true"
PYROSCOPE_SERVER_ADDRESS="https://xxx.grafana.net"
PYROSCOPE_APPLICATION_NAME="lyon-beton-backend"
# Sent as a Bearer token (not Basic Auth — Grafana Cloud's legacy Basic Auth
# push path can reject with "legacy auth cannot be upgraded" on some stacks).
# Generate from: Grafana Cloud portal > stack > Pyroscope > SDK/Alloy config > "Generate now".
PYROSCOPE_AUTH_TOKEN="glc_XXXXXXXXXXXXXXXXXXXXXXX"

# k6 Cloud (Grafana Cloud k6). Requires the k6 Cloud app to be enabled on the
# Grafana Cloud stack (Grafana Cloud portal > k6). Get the token by running
# `k6 cloud login` or from the portal; K6_CLOUD_PROJECT_ID is optional
# (defaults to your stack's default k6 project).
# Used by `pnpm loadtest:cloud`.
K6_CLOUD_TOKEN="YOUR_K6_CLOUD_TOKEN_HERE"
K6_CLOUD_PROJECT_ID=""
